{
  "name": "study-flux",
  "version": "1.0.0",
  "main": "electron/main.js",
  "description": "Elegant study media player with built-in code sandbox.",
  "author": {
    "name": "StudyFlux",
    "email": "support@studyflux.app"
  },
  "homepage": "https://studyflux.app",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron . --no-sandbox\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.400.0",
    "monaco-editor": "^0.49.0",
    "natsort": "^2.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.studyflux.app",
    "productName": "StudyFlux",
    "compression": "store",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "category": "Education",
      "executableArgs": [
        "--no-sandbox"
      ]
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ]
  }
}
